# Mollie test API key — get it from https://my.mollie.com (Developers -> API keys).
# Must start with test_ . If left blank, /convert runs in SIMULATION mode
# (returns a fake checkout URL) so you can still demo the full domino loop
# by hitting /webhooks/mollie manually with { token, amountCents }.
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the server listens on (Cloud Run injects PORT=8080 automatically).
PORT=8080

# Public-facing base URL used to build QR links, Mollie redirectUrl and webhookUrl.
# Locally this is fine as-is. On Cloud Run set it to the service URL.
BASE_URL=http://localhost:8080

# SQLite file path. Locally ./field.db is fine.
# On Cloud Run the only writable dir is /tmp, so set DB_PATH=/tmp/field.db
# (NOTE: SQLite on Cloud Run is EPHEMERAL — wiped on cold start. Demo only.)
DB_PATH=./field.db
